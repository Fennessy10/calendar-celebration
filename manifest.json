{
  "manifest_version": 4,
  "name": "GCal Extension: Mode Switcher",
  "version": "3.0",
  "description": "Choose between Daily PB Chaser and RPG Level Up modes.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://trello.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/calendar/*"],
      "css": ["global.css"],
      "js": ["level.js", "point.js", "soundOnly.js", "colorChanger.js", "pomodoro.js", "focus-day-view.js"]
    },
    {
      "matches": ["https://trello.com/*"],
      "js": ["trello.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.mp3", "statistics.html", "sky.html"],
      "matches": ["<all_urls>"]
    }
  ]
}